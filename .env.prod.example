APP_ENV=production
SECRETS_DIR=/run/secrets
LOG_LEVEL=INFO
LOG_FORMAT=json
PUBLIC_BASE_URL=https://manga.example.com

POSTGRES_USER=manga
POSTGRES_PASSWORD=replace-with-secret
POSTGRES_DB=manga_ai
DATABASE_URL=postgresql+psycopg://manga:replace-with-secret@postgres:5432/manga_ai
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT_URL=https://s3.example.com
S3_PUBLIC_URL=https://cdn.example.com
S3_ACCESS_KEY_ID=replace-with-secret
S3_SECRET_ACCESS_KEY=replace-with-secret
S3_BUCKET_NAME=manga-ai-prod
S3_REGION=us-east-1

API_CORS_ORIGINS=https://manga.example.com
TRUSTED_HOSTS=manga.example.com,api.manga.example.com
MAX_REQUEST_BYTES=26214400
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/webp
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=120
EXPOSE_ERROR_DETAILS=false

MODEL_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
COMFYUI_BASE_URL=
QA_EXPORT_PRESET=draft
QA_MAX_BUBBLE_PANEL_COVERAGE=0.35
QA_MAX_PANEL_OVERLAP_RATIO=0.08
ENABLE_BACKGROUND_JOBS=true
ENABLE_DEV_ADMIN=false

NEXT_PUBLIC_API_BASE_URL=https://api.manga.example.com
API_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_ENABLE_DEV_ADMIN=false
