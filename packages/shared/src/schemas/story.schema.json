{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manga-ai.local/schemas/story.schema.json",
  "title": "StoryBible",
  "type": "object",
  "required": [
    "logline",
    "synopsis",
    "genre",
    "themes",
    "target_audience",
    "tone",
    "main_conflict",
    "world_rules",
    "characters",
    "locations",
    "key_objects",
    "chapter_outline",
    "continuity_rules"
  ],
  "properties": {
    "id": { "type": ["string", "null"], "format": "uuid" },
    "project_id": { "type": ["string", "null"], "format": "uuid" },
    "logline": { "type": "string", "minLength": 1 },
    "synopsis": { "type": "string", "minLength": 1 },
    "genre": { "type": "string", "minLength": 1 },
    "themes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "target_audience": { "type": "string", "minLength": 1 },
    "tone": { "type": "string", "minLength": 1 },
    "main_conflict": { "type": "string", "minLength": 1 },
    "world_rules": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "role", "description", "traits"],
        "properties": {
          "id": { "type": ["string", "null"], "format": "uuid" },
          "name": { "type": "string" },
          "role": { "type": "string" },
          "description": { "type": "string" },
          "traits": { "type": "array", "items": { "type": "string" } },
          "visual_notes": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "locations": { "type": "array", "minItems": 1 },
    "key_objects": { "type": "array", "minItems": 1 },
    "chapter_outline": { "type": "array", "minItems": 1 },
    "continuity_rules": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "style_bible": { "type": ["object", "null"] },
    "created_at": { "type": ["string", "null"], "format": "date-time" },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": true
}
