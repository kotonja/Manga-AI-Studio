{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://manga-ai.local/schemas/render.schema.json",
  "title": "Render",
  "type": "object",
  "required": ["id", "job_id", "panel_id", "storage_key", "width", "height", "mime_type", "created_at"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "job_id": { "type": "string", "format": "uuid" },
    "panel_id": { "type": "string", "format": "uuid" },
    "asset_id": { "type": ["string", "null"], "format": "uuid" },
    "storage_key": { "type": "string" },
    "public_url": { "type": ["string", "null"], "format": "uri" },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "mime_type": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
