# Manga AI Studio controlled private-alpha environment template.
# Copy this file to .env.alpha, replace every placeholder, then run:
#   python scripts/check-alpha-env.py --env-file .env.alpha
#
# Do not commit .env.alpha. Do not use real paid providers for first alpha.

APP_ENV=alpha
PUBLIC_BASE_URL=https://replace-with-alpha-host.example
LOG_LEVEL=INFO
LOG_FORMAT=json
EXPOSE_ERROR_DETAILS=false

# Required alpha auth. Generate strong random values before deploy.
ALPHA_AUTH_ENABLED=true
ALPHA_SESSION_SECRET=replace-with-64-plus-character-random-session-secret
ALPHA_USER_TOKENS=tester-a:replace-with-token-from-scripts-create-alpha-token
ALPHA_ADMIN_TOKEN=replace-with-strong-admin-token
ALPHA_SHARED_PASSWORD=

# Admin/dev access must stay disabled for tester-facing alpha.
ENABLE_DEV_ADMIN=false
NEXT_PUBLIC_ENABLE_DEV_ADMIN=false

# Local token mode is the recommended first alpha mode.
AUTH_PROVIDER_MODE=local
AUTH_PROVIDER_NAME=local
AUTH_FORWARDED_USER_HEADER=X-Authenticated-User
TRUST_EXTERNAL_AUTH_HEADERS=false
AUTH_JWKS_URL=
AUTH_ISSUER=
AUTH_AUDIENCE=

# Database. Replace user, password, host, and database for the deployment.
POSTGRES_USER=manga_alpha
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=manga_ai_alpha
DATABASE_URL=postgresql+psycopg://manga_alpha:replace-with-strong-postgres-password@postgres:5432/manga_ai_alpha

# Redis.
REDIS_URL=redis://redis:6379/0

# Object storage. Keep public reads disabled and route downloads through the API.
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_URL=https://replace-with-alpha-host.example
S3_ACCESS_KEY_ID=replace-with-minio-access-key
S3_SECRET_ACCESS_KEY=replace-with-strong-minio-secret-key
S3_BUCKET_NAME=manga-ai-alpha
S3_REGION=us-east-1
S3_PUBLIC_READ_ENABLED=false
ASSET_DOWNLOAD_MODE=proxy

# API/web networking.
API_CORS_ORIGINS=https://replace-with-alpha-host.example
NEXT_PUBLIC_API_BASE_URL=https://replace-with-alpha-api-host.example
API_INTERNAL_URL=http://api:8000
TRUSTED_HOSTS=replace-with-alpha-host.example,replace-with-alpha-api-host.example,localhost,127.0.0.1

# Mock provider defaults for first controlled alpha.
MODEL_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
COMFYUI_BASE_URL=

# Jobs and QA.
ENABLE_BACKGROUND_JOBS=true
QA_EXPORT_PRESET=draft
QA_MAX_BUBBLE_PANEL_COVERAGE=0.35
QA_MAX_PANEL_OVERLAP_RATIO=0.08

# Safety/privacy defaults.
DEFAULT_PROJECT_ALLOW_TRAINING=false
DEFAULT_PROJECT_ALLOW_PRODUCT_IMPROVEMENT=false
MAX_REQUEST_BYTES=26214400
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/webp
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=120
