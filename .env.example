POSTGRES_USER=manga
POSTGRES_PASSWORD=manga
POSTGRES_DB=manga_ai
APP_ENV=development
SECRETS_DIR=
LOG_LEVEL=INFO
LOG_FORMAT=plain
PUBLIC_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql+psycopg://manga:manga@postgres:5432/manga_ai

REDIS_URL=redis://redis:6379/0

S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET_NAME=manga-ai-dev
S3_REGION=us-east-1
S3_PUBLIC_READ_ENABLED=false
ASSET_DOWNLOAD_MODE=proxy

API_CORS_ORIGINS=http://localhost:3000
MODEL_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
COMFYUI_BASE_URL=
QA_EXPORT_PRESET=draft
QA_MAX_BUBBLE_PANEL_COVERAGE=0.35
QA_MAX_PANEL_OVERLAP_RATIO=0.08
ENABLE_BACKGROUND_JOBS=true
ENABLE_DEV_ADMIN=false
ALPHA_AUTH_ENABLED=false
ALPHA_SHARED_PASSWORD=
ALPHA_USER_TOKENS=
ALPHA_ADMIN_TOKEN=
ALPHA_SESSION_SECRET=
AUTH_PROVIDER_MODE=local
AUTH_PROVIDER_NAME=local
AUTH_FORWARDED_USER_HEADER=X-Authenticated-User
AUTH_JWKS_URL=
AUTH_ISSUER=
AUTH_AUDIENCE=
DEFAULT_PROJECT_ALLOW_TRAINING=false
DEFAULT_PROJECT_ALLOW_PRODUCT_IMPROVEMENT=false
TRUSTED_HOSTS=*
MAX_REQUEST_BYTES=26214400
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_CONTENT_TYPES=image/png,image/jpeg,image/webp
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=120
EXPOSE_ERROR_DETAILS=true

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
API_INTERNAL_URL=http://api:8000
NEXT_PUBLIC_ENABLE_DEV_ADMIN=false
